Cell[BoxData[
 RowBox[{
  RowBox[{"rot", "[", 
   RowBox[{"t_", ",", "i_", ",", "j_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mm", ",", "tt"}], "}"}], ",", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"mm", "=", 
       RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"StringJoin", "[", 
        RowBox[{
         RowBox[{"ToString", "[", "tt", "]"}], ",", "\"\<=\>\"", ",", 
         RowBox[{"ToString", "[", "t", "]"}], ",", "\"\<[\>\"", ",", 
         RowBox[{"ToString", "[", "i", "]"}], ",", "\"\<,\>\"", ",", 
         RowBox[{"ToString", "[", "j", "]"}], ",", "\"\<]\>\""}], "]"}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Cos", "[", "tt", "]"}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Sin", "[", "tt", "]"}]}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"j", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Sin", "[", "tt", "]"}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"j", ",", "j"}], "]"}], "]"}], "=", 
       RowBox[{"Cos", "[", "tt", "]"}]}], ";", "mm"}], ")"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.886633973433816*^9, 3.886633999215843*^9}, {
  3.886634378905818*^9, 3.886634394319886*^9}, {3.8866345156909227`*^9, 
