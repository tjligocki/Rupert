Cell[BoxData[
 RowBox[{
  RowBox[{"rot2", "[", 
   RowBox[{"x_", ",", "i_", ",", "j_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"mm", ",", "xx"}], "}"}], ",", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"mm", "=", 
       RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"StringJoin", "[", 
        RowBox[{
         RowBox[{"ToString", "[", "xx", "]"}], ",", "\"\<=\>\"", ",", 
         RowBox[{"ToString", "[", "x", "]"}], ",", "\"\<[\>\"", ",", 
         RowBox[{"ToString", "[", "i", "]"}], ",", "\"\<,\>\"", ",", 
         RowBox[{"ToString", "[", "j", "]"}], ",", "\"\<]\>\""}], "]"}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"1", "-", "xx"}], "]"}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Sqrt", "[", "xx", "]"}]}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
