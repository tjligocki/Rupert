Cell[BoxData[
 RowBox[{
  RowBox[{"fullRotMat", "[", 
   RowBox[{"t_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "mm", "}"}], ",", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"mm", "=", 
       RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", "n"}], ",", 
        RowBox[{"i", "++"}], ",", 
