              RowBox[{"rot", "[", 
               RowBox[{"t", ",", "i", ",", "j", ",", "n"}], "]"}]}]}], ",", 
            "Nothing"}], "]"}]}], "]"}]}], "]"}], ";", "mm"}], ")"}]}], 
