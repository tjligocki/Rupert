Cell[BoxData[
 RowBox[{
  RowBox[{"MinimizeSumRandom", "[", 
   RowBox[{"a_", ",", "num_", ",", "rep_", ",", "dt_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "b", ",", "n", ",", "pairs", ",", "npairs", ",", "rots", ",", "i", ",", 
      "pair", ",", "rot", ",", "t", ",", "step", ",", "nstep", ",", "tstart", 
      ",", "tprev", ",", "tcur", ",", "count", ",", "perturb", ",", "j", ",", 
      "maxsum"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"b", "=", 
      RowBox[{"EqualSums", "[", "a", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "b", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"pairs", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"m", "[", 
           RowBox[{"i", ",", "j"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "n"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Min", "[", 
             RowBox[{
              RowBox[{"j", "-", "1"}], ",", "m"}], "]"}]}], "}"}]}], "]"}], 
        ",", "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"npairs", "=", 
      RowBox[{"Length", "[", "pairs", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rots", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"IdentityMatrix", "[", "n", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "npairs"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", 
       RowBox[{"i", "\[LessEqual]", "npairs"}], ",", 
       RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"pair", "=", 
         RowBox[{"pairs", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"rot", "=", 
         RowBox[{"rots", "[", 
          RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rot", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"pair", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"pair", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{"Cos", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rot", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"pair", "[", 
             RowBox[{"[", "1", "]"}], "]"}], ",", 
            RowBox[{"pair", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{"-", 
          RowBox[{"Sin", "[", "t", "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rot", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"pair", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"pair", "[", 
             RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{"Sin", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rot", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"pair", "[", 
             RowBox[{"[", "2", "]"}], "]"}], ",", 
            RowBox[{"pair", "[", 
             RowBox[{"[", "2", "]"}], "]"}]}], "]"}], "]"}], "=", 
         RowBox[{"Cos", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"rots", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "=", "rot"}], ";"}]}], 
      "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"step", "=", "0.1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"nstep", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tstart", "=", 
      RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"tprev", "=", "tstart"}], ";", "\[IndentingNewLine]", 
     RowBox[{"tcur", "=", "tstart"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"MaxSum", "[", "b", "]"}]}], "//", "FullForm"}], ",", 
       "\"\<  \>\"", ",", "step", ",", "\"\<  \>\"", ",", "nstep", ",", 
       "\"\<  \>\"", ",", 
       RowBox[{"tcur", "-", "tstart"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"count", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{"step", ">", 
        RowBox[{"1", "/", "1000000000000000"}]}], ",", "\[IndentingNewLine]", 
       
       RowBox[{
        RowBox[{"perturb", "=", "b"}], ";", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", "=", "1"}], ",", 
          RowBox[{"i", "\[LessEqual]", "num"}], ",", 
          RowBox[{"i", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"j", "=", 
            RowBox[{"RandomInteger", "[", 
             RowBox[{"{", 
              RowBox[{"1", ",", "npairs"}], "}"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"perturb", "=", 
            RowBox[{"perturb", ".", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"rots", "[", 
                RowBox[{"[", "j", "]"}], "]"}], "/.", 
               RowBox[{"{", 
                RowBox[{"t", "\[Rule]", 
                 RowBox[{"RandomReal", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"-", "step"}], "/", "num"}], ",", 
                    RowBox[{"step", "/", "num"}]}], "}"}], "]"}]}], "}"}]}], 
              ")"}]}]}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"perturb", "=", 
         RowBox[{"EqualSums", "[", "perturb", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"maxsum", "=", 
         RowBox[{"MaxSum", "[", "perturb", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"maxsum", " ", "<", 
           RowBox[{"MaxSum", "[", "b", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"step", "=", 
            RowBox[{"Min", "[", 
             RowBox[{
              RowBox[{"2.0", "step"}], ",", "1.0"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"b", "=", "perturb"}], ";"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"count", "\[GreaterEqual]", "rep"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"step", "=", 
               RowBox[{"step", "/", 
                RowBox[{"Sqrt", "[", 
                 RowBox[{"Sqrt", "[", 
                  RowBox[{"Sqrt", "[", "2.0", "]"}], "]"}], "]"}]}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"count", "=", "0"}], ";"}], ",", "\[IndentingNewLine]", 
             
             RowBox[{
              RowBox[{"count", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], 
           ";"}]}], "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
        
        RowBox[{"tcur", "=", 
         RowBox[{"AbsoluteTime", "[", "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"tcur", " ", ">", " ", 
           RowBox[{"tprev", "+", "dt"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"tprev", "=", "tcur"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"1", "/", 
               RowBox[{"MaxSum", "[", "b", "]"}]}], "//", "FullForm"}], ",", 
             "\"\<  \>\"", ",", "step", ",", "\"\<  \>\"", ",", "nstep", ",", 
             "\"\<  \>\"", ",", 
             RowBox[{"tcur", "-", "tstart"}]}], "]"}], ";"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Indeterminate", ";"}]}], "\[IndentingNewLine]", "]"}], ";",
         "\[IndentingNewLine]", 
        RowBox[{"nstep", "++"}], ";"}]}], "\[IndentingNewLine]", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"MaxSum", "[", "b", "]"}]}], "//", "FullForm"}], ",", 
       "\"\<  \>\"", ",", "step", ",", "\"\<  \>\"", ",", "nstep", ",", 
       "\"\<  \>\"", ",", 
       RowBox[{"tcur", "-", "tstart"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "b"}]}], "\[IndentingNewLine]", "]"}]}]], "Input",
