Cell[BoxData[
 RowBox[{
  RowBox[{"EqualSums", "[", "a_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "b", ",", "sums", ",", "maxsum", ",", "minsum", ",", "nmax", ",", "nmin",
       ",", "loopnum", ",", "loopmax", ",", "toler", ",", "mint"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"b", "=", "a"}], ";", "\[IndentingNewLine]", 
     RowBox[{"sums", "=", 
      RowBox[{"RowSums", "[", "b", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"maxsum", "=", 
      RowBox[{"Max", "[", "sums", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"minsum", "=", 
      RowBox[{"Min", "[", "sums", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nmax", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"sums", ",", "maxsum"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nmin", "=", 
      RowBox[{
       RowBox[{"Position", "[", 
        RowBox[{"sums", ",", "minsum"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"loopnum", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"loopmax", "=", "500"}], ";", "\[IndentingNewLine]", 
     RowBox[{"toler", "=", 
      RowBox[{"1.0", "/", 
       RowBox[{"10", "^", "13"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"While", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"nmax", "\[NotEqual]", "nmin"}], "&&", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"maxsum", "-", "minsum"}], ")"}], ">", "toler"}], "&&", 
        RowBox[{"loopnum", "<", "loopmax"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"mint", "=", 
