   3.500134844123971*^9, 3.5001348458888817`*^9}, {3.500136142082954*^9, 
   3.500136158705154*^9}, {3.500136193138282*^9, 3.5001361999446*^9}, {
   3.500136434451378*^9, 3.5001365951632557`*^9}, {3.500136653717201*^9, 
   3.500136654747843*^9}, {3.500136751936287*^9, 3.500136759753503*^9}, {
