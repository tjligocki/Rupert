Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"y", "\[Rule]", 
      RowBox[{"ConditionalExpression", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"ArcTan", "[", 
          FractionBox["1", 
           RowBox[{
            SqrtBox[
             RowBox[{"5", "-", 
              RowBox[{"2", " ", 
