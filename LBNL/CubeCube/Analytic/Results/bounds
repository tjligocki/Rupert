#!/bin/csh -f
set len=ideal.len
set max=$1
set m=1
set rows=`cat $len | wc -l`
while ($m <= $max)
  set nm=`expr 2 \* $m`
  set n=`expr $m + 1`
  while ($n <= $nm && $n <= $max)
    set row=`echo $m $n | awk -f bounds.awk`
    if ($row <= $rows) then
      set value=`head -$row $len | tail -1 | awk '{printf("%s",$3);}'`
      echo $m $n $value | awk '{printf("%3d %3d     %s\n",$1,$2,$3);}'
    endif
    @ n++
  end
  @ m++
end
