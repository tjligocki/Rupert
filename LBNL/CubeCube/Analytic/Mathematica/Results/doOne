#!/bin/csh -f
set i = 1;
while ($i < 100)
  echo $i
  set ii=`echo $i | awk '{printf("%03d",$1);}'`
  set jj=`echo $i | awk '{printf("%03d",$1+1);}'`
  set j=`expr $i + 1`

  sed -e "s/TN0/t$i/g" -e "s/TN1/t$j/g" < doOne.awk.template > doOne.awk
  awk -f doOne.awk < doOne.dat > case.$ii.$jj

  @ i++
end
