#!/bin/csh -f
set i = 2;
while ($i < 50)
  echo $i
  set ii=`echo $i | awk '{printf("%03d",2*$1-1);}'`
  set jj=`echo $i | awk '{printf("%03d",2*$1+1);}'`
  set j=`expr $i + 1`

  sed -e "s/TN0/t$i/g" -e "s/TN1/t$j/g" < doTwo.awk.template > doTwo.awk
  awk -f doTwo.awk < doTwo.dat > case.$ii.$jj

  @ i++
end
