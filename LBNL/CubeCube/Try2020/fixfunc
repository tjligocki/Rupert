#!/bin/tcsh -f
sed -e 's/[{}]//g' \
    -e 's/ 0,//g' \
    -e 's/, *$//g'\
    -e 's/Cos\[/cos(/g' \
    -e 's/Sin\[/sin(/g' \
    -e 's/t\[1, 1\]/t[0]/g' \
    -e 's/t\[1, 2\]/t[1]/g' \
    -e 's/t\[1, 3\]/t[2]/g' \
    -e 's/t\[2, 5\]/t[3]/g' \
    -e 's/t\[2, 6\]/t[4]/g' \
    -e 's/t\[2, 7\]/t[5]/g' \
    -e 's/t\[3, 5\]/t[6]/g' \
    -e 's/t\[3, 8\]/t[7]/g' \
    -e 's/t\[3, 9\]/t[8]/g' \
    -e 's/t\[3, 10\]/t[9]/g' \
    -e 's/\]\]/])/g' \
    -e 's/,/ +/g' \
    -e 's/^ /fabs(/g' \
    -e 's/+ /+ fabs(/g' \
    -e 's/ +/) +/g' \
    -e 's/$/)/g' \
    -e 's/ c/*c/g' \
    -e 's/ s/*s/g' \
  $* 
