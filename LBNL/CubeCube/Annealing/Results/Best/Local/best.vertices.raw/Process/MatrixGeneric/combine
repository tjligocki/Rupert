#!/usr/bin/env python

import sys

for fn in sys.argv[1:]:
  f = open(fn,"r")

  l = f.readline().split()

  m = int(l[0])
  n = int(l[1])

  for i in xrange(n):
    l = f.readline().split()

    for j in xrange(m):
      sys.stdout.write("%9.6f " % float(l[j]))

    sys.stdout.write("\n")

  sys.stdout.write("\n")
