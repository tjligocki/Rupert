NF == 2 {
  m = $1;
  n = $2;
  d = 1;
  for (k = m; k >= 2; k--) {
    if (n % k == 0 && m % k == 0) {
      d = k;
      break;
    }
  }
  m = m/d;
  n = n/d;
  if (m == 1) {
    printf("%3d %3d     %19.17lf\n",$1,$2,sqrt(n));
    next;
  }
  if (m == 2) {
    printf("%3d %3d     %19.17lf\n",$1,$2,sqrt(9/8 + (n-3)/2));
    next;
  }
  if (m == n-1 && m >= 2 && m <= 9) {
    printf("%3d %3d     %19.17lf\n",$1,$2,exact[m]);
    next;
  }
}
