       RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"ToExpression", "[", 
       RowBox[{"StringJoin", "[", 
        RowBox[{
         RowBox[{"ToString", "[", "tt", "]"}], ",", "\"\<=\>\"", ",", 
         RowBox[{"ToString", "[", "t", "]"}], ",", "\"\<[\>\"", ",", 
         RowBox[{"ToString", "[", "i", "]"}], ",", "\"\<,\>\"", ",", 
         RowBox[{"ToString", "[", "j", "]"}], ",", "\"\<]\>\""}], "]"}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Cos", "[", "tt", "]"}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
       RowBox[{"-", 
        RowBox[{"Sin", "[", "tt", "]"}]}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"j", ",", "i"}], "]"}], "]"}], "=", 
       RowBox[{"Sin", "[", "tt", "]"}]}], ";", 
      RowBox[{
       RowBox[{"mm", "[", 
        RowBox[{"[", 
         RowBox[{"j", ",", "j"}], "]"}], "]"}], "=", 
