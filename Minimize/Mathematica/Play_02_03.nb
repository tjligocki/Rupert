Cell[BoxData[
 RowBox[{
  RowBox[{"fullRotMat", "[", 
   RowBox[{"t_", ",", "m_", ",", "n_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "mm", "}"}], ",", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"mm", "=", 
       RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ";", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"i", "=", "1"}], ",", 
        RowBox[{"i", "<=", "n"}], ",", 
        RowBox[{"i", "++"}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", 
           RowBox[{"i", "+", "1"}]}], ",", 
          RowBox[{"j", "<=", "n"}], ",", 
          RowBox[{"j", "++"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"i", "<=", "m"}], "||", 
             RowBox[{"j", "<=", "m"}]}], ",", 
            RowBox[{"mm", "=", 
             RowBox[{"mm", ".", 
              RowBox[{"rot", "[", 
               RowBox[{"t", ",", "i", ",", "j", ",", "n"}], "]"}]}]}], ",", 
            "Nothing"}], "]"}]}], "]"}]}], "]"}], ";", "mm"}], ")"}]}], 
   "]"}]}]], "Input",
